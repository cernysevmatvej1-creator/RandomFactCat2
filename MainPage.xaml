<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ApiDeepSeekl.Model"
             x:Class="ApiDeepSeekl.MainPage"
             Title="Факты"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Заголовок -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,10">
                <Label Text="🧠 ИНТЕРЕСНЫЕ ФАКТЫ" 
                       TextColor="#8E8E93" 
                       FontSize="12" 
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Получайте и сохраняйте удивительные факты" 
                       TextColor="#636366" 
                       FontSize="12"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Карточка с ником -->
            <Frame BackgroundColor="#1C1C1E" 
                   CornerRadius="20" 
                   Padding="20" 
                   HasShadow="True"
                   BorderColor="#2C2C2E">

                <VerticalStackLayout Spacing="12">

                    <Label Text="ВАШ НИКНЕЙМ" 
                           TextColor="#8E8E93" 
                           FontSize="11" 
                           CharacterSpacing="1.5"/>

                    <Frame BackgroundColor="#2C2C2E" 
                           CornerRadius="14" 
                           Padding="15,5" 
                           BorderColor="#3A3A3C">
                        <Entry Placeholder="Введите ник" 
                               PlaceholderColor="#636366"
                               Text="{Binding Nik}" 
                               TextColor="White"
                               FontSize="16"
                               BackgroundColor="Transparent"/>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- Карточка получения факта -->
            <Frame BackgroundColor="#1C1C1E" 
                   CornerRadius="20" 
                   Padding="20" 
                   HasShadow="True"
                   BorderColor="#2C2C2E">

                <VerticalStackLayout Spacing="16">

                    <Label Text="ПОЛУЧИТЬ НОВЫЙ ФАКТ" 
                           TextColor="#8E8E93" 
                           FontSize="11" 
                           CharacterSpacing="1.5"/>

                    <!-- Кнопка получения -->
                    <Button Text="🎲 ПОЛУЧИТЬ СЛУЧАЙНЫЙ ФАКТ" 
                            Command="{Binding GetFactCommand}" 
                            Background="#0A84FF" 
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            CharacterSpacing="1"
                            CornerRadius="14"
                            HeightRequest="50"
                            HorizontalOptions="FillAndExpand">
                        <Button.Shadow>
                            <Shadow Brush="#0A84FF" 
                                    Offset="0,4" 
                                    Radius="10" 
                                    Opacity="0.4"/>
                        </Button.Shadow>
                    </Button>

                    <!-- Отображение факта -->
                    <Frame BackgroundColor="#2C2C2E" 
                           CornerRadius="14" 
                           Padding="16"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📌 ТЕКУЩИЙ ФАКТ" 
                                   TextColor="#8E8E93" 
                                   FontSize="10" 
                                   CharacterSpacing="1"/>
                            <Label Text="{Binding TextFact, FallbackValue='Нажмите кнопку, чтобы получить факт'}" 
                                   TextColor="#E5E5EA" 
                                   FontSize="15"
                                   LineBreakMode="WordWrap"
                                   Margin="0,4,0,0"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Кнопка сохранения -->
                    <Button Text="💾 СОХРАНИТЬ ФАКТ" 
                            Command="{Binding SaveFactCommand}" 
                            Background="#30D158" 
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            CharacterSpacing="1"
                            CornerRadius="12"
                            HeightRequest="45"
                            HorizontalOptions="FillAndExpand">
                        <Button.Shadow>
                            <Shadow Brush="#30D158" 
                                    Offset="0,3" 
                                    Radius="8" 
                                    Opacity="0.4"/>
                        </Button.Shadow>
                    </Button>

                </VerticalStackLayout>
            </Frame>

            <!-- Карточка с сохранёнными фактами -->
            <Frame BackgroundColor="#1C1C1E" 
                   CornerRadius="20" 
                   Padding="16" 
                   HasShadow="True"
                   BorderColor="#2C2C2E">

                <VerticalStackLayout Spacing="14">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📚" FontSize="16"/>
                        <Label Text="СОХРАНЁННЫЕ ФАКТЫ" 
                               TextColor="#8E8E93" 
                               FontSize="12" 
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"/>
                    </HorizontalStackLayout>

                    <!-- Список фактов -->
                    <CollectionView ItemsSource="{Binding ListFact}" 
                                    HeightRequest="300">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="local:Fact">

                                <Frame BackgroundColor="#2C2C2E" 
                                       CornerRadius="14" 
                                       Padding="14" 
                                       Margin="0,0,0,8"
                                       HasShadow="False">

                                    <HorizontalStackLayout Spacing="10">

                                        <Frame BackgroundColor="#BF5AF2" 
                                               CornerRadius="10" 
                                               Padding="8"
                                               WidthRequest="32"
                                               HeightRequest="32"
                                               VerticalOptions="Center">
                                            <Label Text="#" 
                                                   TextColor="White" 
                                                   FontSize="12" 
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center" 
                                                   VerticalOptions="Center"/>
                                           
                                        </Frame>

                                        <Label Text="{Binding Text, FallbackValue='Текст факта'}" 
                                               TextColor="#E5E5EA" 
                                               FontSize="13"
                                               LineBreakMode="WordWrap"
                                               VerticalOptions="Center"
                                               HorizontalOptions="FillAndExpand"/>

                                        <Button Text="Удалить" Command="{Binding DeleteFactCommand}" CommandParameter="{Binding .}" Background="Red"/>
                                    </HorizontalStackLayout>

                                </Frame>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- Кнопка гостевого входа -->
            <Button Text="👤 ВОЙТИ КАК ГОСТЬ" 
                    Command="{Binding LoginCommand}" 
                    Background="#5E5CE6" 
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold"
                    CharacterSpacing="1"
                    CornerRadius="14"
                    HeightRequest="55"
                    Margin="0,5,0,0">
                <Button.Shadow>
                    <Shadow Brush="#5E5CE6" 
                            Offset="0,4" 
                            Radius="10" 
                            Opacity="0.4"/>
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>